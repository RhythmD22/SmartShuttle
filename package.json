{
  "name": "smartshuttle",
  "version": "1.0.0",
  "description": "SmartShuttle - Live Shuttle Tracker",
  "type": "module",
  "scripts": {
    "start": "vercel dev",
    "lint": "eslint js/ api/ service-worker.js",
    "format": "prettier --write \"**/*.{js,css,html,json}\""
  },
  "dependencies": {},
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "serviceworker": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "globals": {
      "L": "readonly",
      "SS": "readonly"
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  }
}